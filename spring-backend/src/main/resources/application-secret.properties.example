########################################
## Secret properties TEMPLATE
## Copy this file to application-secret.properties
## and fill in your actual values.
## application-secret.properties is git-ignored.
########################################

# Database
DB_URL=jdbc:postgresql://localhost:5432/issuerdb
DB_USERNAME=postgres
DB_PASSWORD=<your-db-password>

# Brevo (email)
BREVO_API_KEY=<your-brevo-api-key>
BREVO_SENDER_EMAIL=<your-sender-email>

# Cerebras AI
CEREBRAS_API_KEY=<your-cerebras-api-key>

# AES-256 encryption key (64 hex chars)
ENCRYPTION_AES_KEY=<your-64-hex-char-key>
